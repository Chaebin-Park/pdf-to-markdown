{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf-to-markdown",
  "version": "0.1.5",
  "identifier": "com.chaebin.pdf-to-markdown",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PDF to Markdown",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://localhost:* 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5RUM1ODE5ODc3RjM4MTcKUldRWE9IK0hHVmpzK2EzYW5DVFNwbmV4bU5OdzU5QW5zam5QTXpYaDJ0aVEwaGdtRTJRZ3BxZ0sK",
      "endpoints": [
        "https://github.com/Chaebin-Park/pdf-to-markdown/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../server/app/build/libs/server.jar": "server.jar",
      "resources/uv-macos-arm64": "uv-macos-arm64"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
